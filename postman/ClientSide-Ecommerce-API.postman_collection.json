      "name": "OAuth (Google)",
      "item": [
        {
          "name": "GET /api/oauth/callback/google (browser only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/oauth/callback/google?code=PASTE_CODE&state=PASTE_STATE",
            "description": "Google redirects here with **`code`** and **`state`**. Not useful to run manually in Postman unless you paste real OAuth params immediately after redirect. On success sets **`storefront_oauth_exchange`** cookie."
          },
          "response": []
        },
        {
          "name": "POST /api/oauth/sign-in/social",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "{{corsOrigin}}" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"disableRedirect\": true,\n  \"callbackURL\": \"{{baseUrl}}/\"\n}"
            },
            "url": "{{baseUrl}}/api/oauth/sign-in/social",
            "description": "**`disableRedirect: true`** — **200** `{ \"url\" }` for opening Google in browser.\n\nOmit **`disableRedirect`** for **302** redirect (browser + cookie state).\n\nTenant: **`x-shop-id`** header (preferred) or **`additionalData.shopId`** (header wins if both sent).\n\n**503** if Google OAuth env missing."
          },
          "response": []
        }
      ]
    },
