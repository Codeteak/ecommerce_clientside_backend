        {
          "name": "POST /storefront/cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
            "url": "{{baseUrl}}/storefront/cart",
            "description": "Create or get cart for guest (cookie session) or customer (Bearer token)."
          },
          "response": []
        },
        {
          "name": "GET /storefront/cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const code = pm.response.code;",
                  "if (code === 200 || code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.summary) {",
                  "    const sub = j.summary.subtotal_before_coupon_minor != null",
                  "      ? j.summary.subtotal_before_coupon_minor",
                  "      : j.summary.subtotal_minor;",
                  "    if (sub != null) pm.collectionVariables.set('cartSubtotalMinor', String(sub));",
                  "  }",
                  "  if (j.items && j.items.length) {",
                  "    const first = j.items.find((it) => it.product_id && !it.is_bundle_reward) || j.items[0];",
                  "    if (first && first.id && !String(first.id).includes(':bundle-reward')) {",
                  "      pm.collectionVariables.set('cartItemId', first.id);",
                  "    }",
                  "    if (first && first.product_id) pm.collectionVariables.set('productId', first.product_id);",
                  "  }",
                  "  if (j.promotions && j.promotions.coupon) {",
                  "    console.log('coupon', j.promotions.coupon.status, j.promotions.coupon.reason_code || '');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
            "url": {
              "raw": "{{baseUrl}}/storefront/cart",
              "host": ["{{baseUrl}}"],
              "path": ["storefront", "cart"],
              "query": [
                {
                  "key": "couponCode",
                  "value": "{{couponCode}}",
                  "description": "Optional — preview coupon on cart (enable in Params)",
                  "disabled": true
                }
              ]
            },
            "description": "Full cart view: `cartId`, `items[]`, `summary`, `promotions`.\n\n**Query:** optional `couponCode` — invalid codes return `promotions.coupon.status: not_applicable` with `reason_code` / `reason_message` (code is not cleared).\n\n**Items:** live SKU/bundle pricing (`list_price_minor`, `final_price_minor`, `line_total_minor`, …), `price_updated` when catalog price changed. Bundle promos may add a read-only `…:bundle-reward` line.\n\n**Summary:** `subtotal_minor`, `subtotal_before_coupon_minor`, `promotion_discount_minor`, `coupon_discount_minor`, `currency`.\n\n**Promotions:** `auto`, `coupon`, `suggested_coupons` (up to 3). Full coupon list: `GET /storefront/coupons`.\n\nTest script sets `{{cartSubtotalMinor}}`, `{{cartItemId}}`, `{{productId}}`."
          },
          "response": []
        },
        {
          "name": "POST /storefront/cart/items",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const code = pm.response.code;",
                  "if (code === 200 || code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.summary) {",
                  "    const sub = j.summary.subtotal_before_coupon_minor != null",
                  "      ? j.summary.subtotal_before_coupon_minor",
                  "      : j.summary.subtotal_minor;",
                  "    if (sub != null) pm.collectionVariables.set('cartSubtotalMinor', String(sub));",
                  "  }",
                  "  if (j.items && j.items.length) {",
                  "    const first = j.items.find((it) => it.product_id && !it.is_bundle_reward) || j.items[0];",
                  "    if (first && first.id && !String(first.id).includes(':bundle-reward')) {",
                  "      pm.collectionVariables.set('cartItemId', first.id);",
                  "    }",
                  "    if (first && first.product_id) pm.collectionVariables.set('productId', first.product_id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"delta\": 1\n}"
            },
            "url": "{{baseUrl}}/storefront/cart/items",
            "description": "Add or merge a line. Returns **201** + full cart body (same shape as GET).\n\n**Body:** `productId` + **`quantity`** or **`delta`** (integer). Optional **`couponCode`**.\n\n**Rules:** max **99** per line; merges qty if product already in cart; `PRODUCT_UNAVAILABLE` if product is not sellable.\n\nAlternate body example: `{ \"productId\": \"…\", \"quantity\": 2, \"couponCode\": \"SAVE10\" }`."
          },
          "response": []
        },
        {
          "name": "PATCH /storefront/cart/items/:itemId (delta +1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const code = pm.response.code;",
                  "if (code === 200 || code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.summary) {",
                  "    const sub = j.summary.subtotal_before_coupon_minor != null",
                  "      ? j.summary.subtotal_before_coupon_minor",
                  "      : j.summary.subtotal_minor;",
                  "    if (sub != null) pm.collectionVariables.set('cartSubtotalMinor', String(sub));",
                  "  }",
                  "  if (j.items && j.items.length) {",
                  "    const first = j.items.find((it) => it.product_id && !it.is_bundle_reward) || j.items[0];",
                  "    if (first && first.id && !String(first.id).includes(':bundle-reward')) {",
                  "      pm.collectionVariables.set('cartItemId', first.id);",
                  "    }",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delta\": 1\n}"
            },
            "url": "{{baseUrl}}/storefront/cart/items/{{cartItemId}}",
            "description": "Increase quantity by 1 (`delta`). Returns **200** + full cart.\n\nSet `{{cartItemId}}` from a paid line (not `…:bundle-reward`). Optional `couponCode` in body.\n\n**Errors (400):** `MINIMUM_QUANTITY` (only when `delta` is negative at qty 1), `LINE_QUANTITY_CAP` (max 99), `PRODUCT_UNAVAILABLE`."
          },
          "response": []
        },
        {
          "name": "PATCH /storefront/cart/items/:itemId (delta -1)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delta\": -1\n}"
            },
            "url": "{{baseUrl}}/storefront/cart/items/{{cartItemId}}",
            "description": "Decrease quantity by 1. At quantity **1**, returns **400** `MINIMUM_QUANTITY` — use DELETE to remove the line instead.\n\nOptional: `{ \"quantity\": 5 }` to set an exact qty (still max 99)."
          },
          "response": []
        },
        {
          "name": "PATCH /storefront/cart/items/:itemId (quantity + coupon)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2,\n  \"couponCode\": \"{{couponCode}}\"\n}"
            },
            "url": "{{baseUrl}}/storefront/cart/items/{{cartItemId}}",
            "description": "Set absolute `quantity` and optionally re-price with `couponCode`. Returns **200** + full cart."
          },
          "response": []
        },
        {
          "name": "DELETE /storefront/cart/items/:itemId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const code = pm.response.code;",
                  "if (code === 200 || code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.summary) {",
                  "    const sub = j.summary.subtotal_before_coupon_minor != null",
                  "      ? j.summary.subtotal_before_coupon_minor",
                  "      : j.summary.subtotal_minor;",
                  "    if (sub != null) pm.collectionVariables.set('cartSubtotalMinor', String(sub));",
                  "  }",
                  "  if (j.items && j.items.length) {",
                  "    const first = j.items.find((it) => it.product_id && !it.is_bundle_reward) || j.items[0];",
                  "    if (first && first.id && !String(first.id).includes(':bundle-reward')) {",
                  "      pm.collectionVariables.set('cartItemId', first.id);",
                  "    }",
                  "  } else {",
                  "    pm.collectionVariables.set('cartItemId', '00000000-0000-0000-0000-000000000000');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"couponCode\": \"{{couponCode}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/storefront/cart/items/{{cartItemId}}",
            "description": "Remove one paid cart line. Returns **200** + full cart body (empty cart is valid).\n\n**Body:** optional `{}` or `{ \"couponCode\": \"SAVE10\" }` to re-price remaining lines. Do not DELETE `…:bundle-reward` ids — update the paid line instead."
          },
          "response": []
        },
        {
          "name": "Promotions — local test flow",
          "description": "Run top-to-bottom after OTP verify, `POST /storefront/address`, and `POST /storefront/cart/items`.\n\n1. GET cart → saves `cartSubtotalMinor` (and `cartItemId`)\n1b. (optional) GET cart with `couponCode` or PATCH item with coupon — check `promotions.coupon` on cart\n2. List coupons (use subtotal from step 1)\n3. Checkout with optional `couponCode`\n\nAmounts are **minor units** (INR paise). `percentBps` 1000 = 10% off.",
          "item": [
            {
              "name": "1. GET cart (save subtotal)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const code = pm.response.code;",
                      "if (code === 200 || code === 201) {",
                      "  const j = pm.response.json();",
                      "  if (j.summary) {",
                      "    const sub = j.summary.subtotal_before_coupon_minor != null",
                      "      ? j.summary.subtotal_before_coupon_minor",
                      "      : j.summary.subtotal_minor;",
                      "    if (sub != null) {",
                      "      pm.collectionVariables.set('cartSubtotalMinor', String(sub));",
                      "      console.log('cartSubtotalMinor', sub);",
                      "    }",
                      "  }",
                      "  if (j.items && j.items.length) {",
                      "    const first = j.items.find((it) => it.product_id && !it.is_bundle_reward) || j.items[0];",
                      "    if (first && first.id && !String(first.id).includes(':bundle-reward')) {",
                      "      pm.collectionVariables.set('cartItemId', first.id);",
                      "    }",
                      "    if (first && first.product_id) pm.collectionVariables.set('productId', first.product_id);",
                      "  }",
                      "  if (j.promotions && j.promotions.coupon) {",
                      "    console.log('coupon', j.promotions.coupon.status);",
                      "  }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
                "url": "{{baseUrl}}/storefront/cart",
                "description": "Loads cart with live SKU/bundle pricing. Saves `{{cartSubtotalMinor}}` (pre-coupon subtotal) for coupon eligibility."
              },
              "response": []
            },
            {
              "name": "1b. GET cart (preview couponCode)",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
                "url": {
                  "raw": "{{baseUrl}}/storefront/cart?couponCode={{couponCode}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["storefront", "cart"],
                  "query": [{ "key": "couponCode", "value": "{{couponCode}}" }]
                },
                "description": "Preview `{{couponCode}}` on the cart. Check `promotions.coupon.status` (`applied` | `not_applicable`) and `reason_message` if not applicable. Code is kept even when not applicable."
              },
              "response": []
            },
            {
              "name": "2. GET coupons (all visible)",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
                "url": {
                  "raw": "{{baseUrl}}/storefront/coupons?cartSubtotalMinor={{cartSubtotalMinor}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["storefront", "coupons"],
                  "query": [
                    {
                      "key": "cartSubtotalMinor",
                      "value": "{{cartSubtotalMinor}}",
                      "description": "From GET cart summary.subtotal_minor (optional but recommended)"
                    }
                  ]
                },
                "description": "Lists coupon codes for the shop. First-order / new-customer ineligible codes are **omitted**. Below-min-cart codes stay visible with `eligibility.applicable: false` unless `onlyApplicable=true`."
              },
              "response": []
            },
            {
              "name": "2b. GET coupons (onlyApplicable)",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
                "url": {
                  "raw": "{{baseUrl}}/storefront/coupons?onlyApplicable=true&cartSubtotalMinor={{cartSubtotalMinor}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["storefront", "coupons"],
                  "query": [
                    { "key": "onlyApplicable", "value": "true" },
                    { "key": "cartSubtotalMinor", "value": "{{cartSubtotalMinor}}" }
                  ]
                },
                "description": "Same as list but drops coupons where `eligibility.applicable` is false (e.g. min subtotal not met)."
              },
              "response": []
            },
            {
              "name": "2c. GET coupons (filter by code)",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
                "url": {
                  "raw": "{{baseUrl}}/storefront/coupons?code={{couponCode}}&cartSubtotalMinor={{cartSubtotalMinor}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["storefront", "coupons"],
                  "query": [
                    { "key": "code", "value": "{{couponCode}}" },
                    { "key": "cartSubtotalMinor", "value": "{{cartSubtotalMinor}}" }
                  ]
                },
                "description": "Lookup one code (case-insensitive; stored uppercase)."
              },
              "response": []
            },
            {
              "name": "3. POST checkout (no coupon)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const j = pm.response.json();",
                      "  if (j.orderId) pm.collectionVariables.set('lastOrderId', j.orderId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-shop-id", "value": "{{shopId}}" },
                  { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"notes\": \"Postman test — no coupon\"\n}"
                },
                "url": "{{baseUrl}}/storefront/checkout",
                "description": "Checkout with automatic SKU/bundle promos only. Requires address + serviceable location + non-empty cart.\n\n**201:** `orderId`, `orderNumber`, `subtotal_minor`, `promotion_discount_minor`, `coupon_discount_minor` (0), `delivery_fee_minor`, `total_minor`, `coupon_code` (null)."
              },
              "response": []
            },
            {
              "name": "3b. POST checkout (with couponCode)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "pm.collectionVariables.set('idempotencyKey', 'checkout-coupon-' + Date.now());"
                    ],
                    "type": "text/javascript"
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const j = pm.response.json();",
                      "  pm.test('coupon applied', function () {",
                      "    pm.expect(j.coupon_code).to.eql(pm.collectionVariables.get('couponCode'));",
                      "  });",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-shop-id", "value": "{{shopId}}" },
                  { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"notes\": \"Postman test — with coupon\",\n  \"couponCode\": \"{{couponCode}}\"\n}"
                },
                "url": "{{baseUrl}}/storefront/checkout",
                "description": "**Apply coupon** (only endpoint). `couponCode` is uppercased server-side. One code per order.\n\n**Errors (400):** `EMPTY_CART_WITH_COUPON`, `COUPON_NOT_FOUND`, `COUPON_EXHAUSTED`, `MIN_SUBTOTAL_NOT_MET`, `FIRST_ORDER_ONLY_NOT_MET`, `NEW_CUSTOMER_ONLY_NOT_MET`, `COUPON_NO_CART_BENEFIT`, `PRODUCT_UNAVAILABLE`, `PRICE_CHANGED`, `ADDRESS_NOT_SERVICEABLE`.\n\nPrerequest generates a fresh `Idempotency-Key` per run."
              },
              "response": []
            }
          ]
        },
        {
          "name": "GET /storefront/coupons",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
            "url": {
              "raw": "{{baseUrl}}/storefront/coupons?cartSubtotalMinor={{cartSubtotalMinor}}&onlyApplicable=false",
              "host": ["{{baseUrl}}"],
              "path": ["storefront", "coupons"],
              "query": [
                { "key": "cartSubtotalMinor", "value": "{{cartSubtotalMinor}}" },
                { "key": "onlyApplicable", "value": "false" },
                { "key": "code", "value": "{{couponCode}}", "disabled": true }
              ]
            },
            "description": "List coupons (Bearer + shop membership). Query: `code`, `cartSubtotalMinor`, `onlyApplicable`. Response: `promotionsPaused`, `settings`, `coupons[]` with `benefits` and `eligibility`."
          },
          "response": []
        },
        {
          "name": "POST /storefront/checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Leave at the door\",\n  \"couponCode\": \"{{couponCode}}\"\n}"
            },
            "url": "{{baseUrl}}/storefront/checkout",
            "description": "Place order. Optional `couponCode`. Reprices from live DB; writes `promotion_redemptions` when coupon used. Clears cart on success.\n\nSet `couponCode` collection var empty string to omit coupon, or remove field from body."
          },
          "response": []
        },
        {
          "name": "POST /storefront/checkout (no coupon)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}-no-coupon" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Leave at the door\"\n}"
            },
            "url": "{{baseUrl}}/storefront/checkout",
            "description": "Checkout without `couponCode` (auto promos only)."
          },
          "response": []
        },
        {
          "name": "POST /storefront/profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Buyer Name\",\n  \"phone\": \"+919999999999\"\n}"
            },
            "url": "{{baseUrl}}/storefront/profile",
            "description": "Update storefront profile fields (at least one of `displayName` or `phone`)."
          },
          "response": []
        },
        {
          "name": "GET /storefront/address",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
            "url": "{{baseUrl}}/storefront/address",
            "description": "Get storefront delivery address."
          },
          "response": []
        },
        {
          "name": "POST /storefront/address",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"line1\": \"10 Example Street\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"KA\",\n  \"postalCode\": \"560001\",\n  \"country\": \"IN\",\n  \"lat\": 12.9716,\n  \"lng\": 77.5946\n}"
            },
            "url": "{{baseUrl}}/storefront/address",
            "description": "Create or replace storefront address."
          },
          "response": []
        },
        {
          "name": "PATCH /storefront/address",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-shop-id", "value": "{{shopId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"landmark\": \"Near metro station\"\n}"
            },
            "url": "{{baseUrl}}/storefront/address",
            "description": "Patch storefront address fields."
          },
          "response": []
        },
        {
          "name": "GET /storefront/orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
            "url": "{{baseUrl}}/storefront/orders",
            "description": "List storefront customer orders."
          },
          "response": []
        },
        {
          "name": "GET /storefront/orders/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-shop-id", "value": "{{shopId}}" }],
            "url": "{{baseUrl}}/storefront/orders/00000000-0000-0000-0000-000000000000",
            "description": "Get one order detail by order id."
          },
          "response": []
        }
      ]
    }
  ]
